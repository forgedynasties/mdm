# Server
PORT=8080

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=mdm
DB_PASSWORD=changeme
DB_NAME=mdm

# Shared key — every AOSP device must send this in X-API-Key header
DEVICE_API_KEY=change-this-to-a-long-random-string

# Dashboard login
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Session cookie secret (defaults to DEVICE_API_KEY if not set)
SESSION_SECRET=another-long-random-string
